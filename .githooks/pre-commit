#!/bin/bash
# Pre-commit hook: auto-update version files with the next commit number
# and project stats (line counts, module counts, test session counts).

NEXT=$(( $(git rev-list --count HEAD) + 1 ))

# Compute project stats
JS_LINES=$(find js -name '*.js' -print0 | xargs -0 cat | wc -l | tr -d ' ')
JS_MODULES=$(find js -name '*.js' -not -path '*/levels/*' | wc -l | tr -d ' ')
JS_MODULES_TOTAL=$(find js -name '*.js' | wc -l | tr -d ' ')
LEVEL_MODULES=$(find js/levels -name '*.js' | wc -l | tr -d ' ')
SESSION_COUNT=$(find test/comparison/sessions -name '*.session.json' | wc -l | tr -d ' ')
UNIT_TEST_COUNT=$(find test/unit -name '*.test.js' -o -name '*.test.mjs' | wc -l | tr -d ' ')

# Round JS lines to nearest thousand for display (e.g., 197214 -> "197,000+")
JS_LINES_K=$(( (JS_LINES / 1000) * 1000 ))
JS_LINES_DISPLAY=$(printf "%'d+" "$JS_LINES_K")

cat > js/version.js <<EOF
// version.js -- Auto-generated by .githooks/pre-commit. Do not edit by hand.
export const COMMIT_NUMBER = ${NEXT};
EOF

cat > _data/version.yml <<EOF
commit_number: ${NEXT}
js_lines: ${JS_LINES}
js_lines_display: "${JS_LINES_DISPLAY}"
js_modules: ${JS_MODULES}
js_modules_total: ${JS_MODULES_TOTAL}
level_modules: ${LEVEL_MODULES}
session_count: ${SESSION_COUNT}
unit_test_count: ${UNIT_TEST_COUNT}
EOF

git add js/version.js _data/version.yml

exit 0
