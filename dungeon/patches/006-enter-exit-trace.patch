+C PROB-		Compute probability
+C
+C Declarations
+C
+	LOGICAL FUNCTION PROB(G,B)
+	IMPLICIT INTEGER (A-Z)
+	INCLUDE 'dparam.for'
+C
+	I=G					! assume good luck.
+	IF(BADLKF) I=B				! if bad, too bad.
+	PROB=RND(100).LT.I			! compute.
+	RETURN
+C
+	END
