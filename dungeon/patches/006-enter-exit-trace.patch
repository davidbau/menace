-13000	GHERE=(RM.GE.SLID1).AND.(RM.LE.SLEDG)
-	RETURN
-C
-C 14000--	Slide
-C
-14000	GHERE=(RM.GE.SLIDE).OR.((RM.GE.SLID1).AND.(RM.LE.SLEDG))
-	RETURN
-C
-C 15000--	Bunch pseudo object
