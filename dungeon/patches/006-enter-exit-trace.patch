+C
+C RND - Return a random integer mod n
+C
+	INTEGER FUNCTION RND (N)
+	IMPLICIT INTEGER (A-Z)
+	REAL RAN
+	COMMON /SEED/ RNSEED
+	INTEGER RNGCNT
+	COMMON /RNGLOG/ RNGCNT
+
+	RAN = RAND(0)
+	RND = RAN*FLOAT(N)
+	RNGCNT = RNGCNT + 1
+	WRITE(0,*) 'RNG #',RNGCNT,': val=',RAN,' n=',N,
+	1 ' result=',RND
+	RETURN
+
+	END
+C
+C INIRND - Initialize random number seed
+C
+	SUBROUTINE INIRND (LOW, HIGH)
+	IMPLICIT INTEGER (A-Z)
+	COMMON /SEED/ RNSEED
+
+	CALL SRAND(IOR((ISHFT(HIGH,16)+LOW), 1))
+	RETURN
+
+	END
