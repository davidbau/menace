+C GTTIME-- Get total time played
+C
+C Declarations
+C
+	SUBROUTINE GTTIME(T)
+	IMPLICIT INTEGER (A-Z)
+	INCLUDE 'dparam.for'
+C
+	CALL ITIME(TMARRAY)
+	H=TMARRAY(1)
+	M=TMARRAY(2)
+	S=TMARRAY(3)
+	T=((H*60)+M)-((SHOUR*60)+SMIN)
+	IF(T.LT.0) T=T+1440
+	T=T+PLTIME
+	RETURN
+C
+	END
