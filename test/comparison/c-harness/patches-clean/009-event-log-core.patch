+/*
+ * Event logging.
+ *
+ * Writes ^event lines interleaved with the RNG log so differential-debug
+ * consumers can correlate state-changing events with the PRNG stream.
+ */
+void
+event_log(const char *fmt, ...)
+{
+    va_list ap;
+
+    if (!rng_logfile)
+        return;
+    fputc('^', rng_logfile);
+    va_start(ap, fmt);
+    vfprintf(rng_logfile, fmt, ap);
+    va_end(ap);
+    fputc('\n', rng_logfile);
+}
