+staticfn const char *
+harness_getenv_with_fallback(const char *nethack_key, const char *webhack_key)
+{
+    const char *value;
+
+    value = getenv(nethack_key);
+    if (value && *value)
+        return value;
+    if (!webhack_key || !*webhack_key)
+        return (const char *) 0;
+    value = getenv(webhack_key);
+    return (value && *value) ? value : (const char *) 0;
+}
 
