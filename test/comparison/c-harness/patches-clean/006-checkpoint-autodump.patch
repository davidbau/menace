+staticfn void
+json_write_escaped(FILE *fp, const char *s)
+{
+    int c;
+
+    if (!s)
+        return;
+    while ((c = (unsigned char) *s++) != '\0') {
+        if (c == '"' || c == '\\') {
+            fputc('\\', fp);
+            fputc(c, fp);
+        } else if (c >= 0x20 && c <= 0x7e) {
+            fputc(c, fp);
+        } else {
+            fprintf(fp, "\\u%04x", c & 0xff);
+        }
+    }
+}
