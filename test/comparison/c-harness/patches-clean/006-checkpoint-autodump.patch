+staticfn void
+harness_auto_mapdump(void)
+{
+    const char *dir = nh_getenv("NETHACK_MAPDUMP_DIR");
+    static long dump_serial = 0;
+    char dump_id[64], pathbuf[BUFSZ];
+    FILE *fp;
+
+    if (!dir || !*dir)
+        return;
+
+    (void) Snprintf(dump_id, sizeof dump_id, "d%dl%d_%03ld",
+                    (int) u.uz.dnum, (int) u.uz.dlevel, ++dump_serial);
+    (void) Snprintf(pathbuf, sizeof pathbuf, "%s/%s", dir, dump_id);
+
+    fp = fopen(pathbuf, "w");
+    if (!fp) {
+        raw_printf("mapdump: cannot open %s for writing.", pathbuf);
+        return;
+    }
+
+    (void) fputc('T', fp); harness_mapdump_rle_grid(fp, 0); (void) fputc('\n', fp);
+    (void) fputc('F', fp); harness_mapdump_rle_grid(fp, 1); (void) fputc('\n', fp);
+    (void) fputc('H', fp); harness_mapdump_rle_grid(fp, 2); (void) fputc('\n', fp);
+    (void) fputc('L', fp); harness_mapdump_rle_grid(fp, 3); (void) fputc('\n', fp);
+    (void) fputc('R', fp); harness_mapdump_rle_grid(fp, 4); (void) fputc('\n', fp);
+    (void) fputc('W', fp); harness_mapdump_rle_grid(fp, 5); (void) fputc('\n', fp);
+    (void) fprintf(fp, "U%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%ld,%d,%d,%d,%d,%d\n",
+                   (int) u.ux, (int) u.uy,
+                   (int) u.uhp, (int) u.uhpmax,
+                   (int) u.uen, (int) u.uenmax,
+                   (int) gm.multi, (int) u.utrap, (int) u.utraptype,
+                   (int) svc.context.move, (long) svm.moves,
+                   Confusion ? 1 : 0, Stunned ? 1 : 0,
+                   Blind ? 1 : 0, Hallucination ? 1 : 0,
+                   Fumbling ? 1 : 0);
+    (void) fprintf(fp, "A%ld,%ld\n", (long) svm.moves, (long) gh.hero_seq);
+    harness_mapdump_sparse_lists(fp);
+    (void) fclose(fp);
+
+    event_log("mapdump[%s]", dump_id);
+}
 
