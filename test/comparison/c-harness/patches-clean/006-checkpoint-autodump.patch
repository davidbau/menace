+staticfn int
+harness_mapdump_minvent_count(struct monst *mtmp)
+{
+    int n = 0;
+    struct obj *otmp;
+
+    if (!mtmp)
+        return 0;
+    for (otmp = mtmp->minvent; otmp; otmp = otmp->nobj)
+        n++;
+    return n;
+}
