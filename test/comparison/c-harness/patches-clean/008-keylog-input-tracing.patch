 struct window_procs tty_procs = {
@@ -4205,6 +4265,7 @@ tty_nhgetch(void)
         print_vt_code2(AVTC_SELECT_WINDOW, tmp);
     }
 #endif /* TTY_TILES_ESCCODES */
+    nh_keylog_event(i);
     return i;
 }
