+/* Shadow frame buffer for direct screen capture (no tmux needed).
+ * Updated at every visible character write; serialized at nhgetch(). */
+typedef struct {
+    char ch;
+    unsigned char fg;    /* 0-15 NH color, 7=default gray */
+    unsigned char attr;  /* bit0=inverse, bit1=bold, bit2=underline */
+} nomux_cell;
+
+extern nomux_cell nomux_buf[24][80];
+extern void nomux_clear_screen(void);
+extern void nomux_clear_to_eol(int row, int col);
+extern void nomux_set_attr(int attr);   /* ATR_INVERSE etc */
+extern void nomux_end_attr(void);
+extern void nomux_set_fg(int color);
+extern void nomux_end_fg(void);
+extern char *nomux_capture_screen(void);
+extern void nomux_get_cursor(int *cx, int *cy);
+/* Macro: write visible char to shadow buffer at current cursor pos */
+#define NOMUX_CH(ch) do { if (ttyDisplay && (ch) >= 32 && ttyDisplay->cury >= 0 && ttyDisplay->cury < 24 && ttyDisplay->curx >= 0 && ttyDisplay->curx < 80) { nomux_buf[ttyDisplay->cury][ttyDisplay->curx].ch = (char)(ch); nomux_buf[ttyDisplay->cury][ttyDisplay->curx].fg = nomux_buf[0][0].fg; /* uses current fg from last nomux_set_fg */ nomux_buf[ttyDisplay->cury][ttyDisplay->curx].attr = nomux_buf[0][0].attr; } } while(0)
+#endif /* NOMUX_CAPTURE */
