+
+#ifdef NOMUX_CAPTURE
+/* ================================================================
+ * NOMUX shadow frame buffer
+ * ================================================================ */
+nomux_cell nomux_buf[24][80];
+static unsigned char nomux_fg = 7;
+static unsigned char nomux_attr = 0;
+
+void nomux_clear_screen(void) {
+    int r, c;
+    for (r = 0; r < 24; r++)
+        for (c = 0; c < 80; c++) {
+            nomux_buf[r][c].ch = ' ';
+            nomux_buf[r][c].fg = 7;
+            nomux_buf[r][c].attr = 0;
+        }
+}
+
+void nomux_clear_to_eol(int row, int col) {
+    int c;
+    if (row < 0 || row >= 24) return;
+    for (c = (col < 0 ? 0 : col); c < 80; c++) {
+        nomux_buf[row][c].ch = ' ';
+        nomux_buf[row][c].fg = 7;
+        nomux_buf[row][c].attr = 0;
+    }
+}
+
+void nomux_set_attr(int attr) {
+    if (attr == ATR_INVERSE) nomux_attr |= 1;
+    else if (attr == ATR_BOLD) nomux_attr |= 2;
+    else if (attr == ATR_ULINE) nomux_attr |= 4;
+}
+void nomux_end_attr(void) { nomux_attr = 0; }
+
+void nomux_set_fg(int color) {
+    nomux_fg = (color == NO_COLOR) ? 7 : (unsigned char)(color & 0xf);
+}
+void nomux_end_fg(void) { nomux_fg = 7; }
+
+/* Write one visible char to shadow buffer at ttyDisplay cursor */
+void nomux_putch(int ch) {
+    int row, col;
+    if (!ttyDisplay) return;
+    if (ch < 32) return;
+    row = ttyDisplay->cury;
+    col = ttyDisplay->curx;
+    if (row >= 0 && row < 24 && col >= 0 && col < 80) {
+        nomux_buf[row][col].ch = (char) ch;
+        nomux_buf[row][col].fg = nomux_fg;
+        nomux_buf[row][col].attr = nomux_attr;
+    }
+}
+#endif /* NOMUX_CAPTURE */
