+/* screendump_if_enabled -- write curses stdscr cell state to file.
+ *
+ * Each row is one line: 80 cells encoded as ANSI escape sequences
+ * from the actual curses attribute state (not raw terminal output).
+ *
+ * Triggered after every nhgetch if NETHACK_SCREENDUMP env var is set.
+ * The file is overwritten each time (latest screen only).
+ */
+staticfn void
+screendump_if_enabled(void)
+{
+    static const char *fname = NULL;
+    static int checked = 0;
+    FILE *fp;
+
+    if (!checked) {
+        fname = getenv("NETHACK_SCREENDUMP");
+        checked = 1;
+    }
+    if (!fname)
+        return;
+
+    fp = fopen(fname, "w");
+    if (!fp)
+        return;
+    do_screendump(fp);
+    fclose(fp);
+}
+
+staticfn void
+do_screendump(FILE *fp)
+{
+    int y, x;
+    int rows = 24, cols = 80;
+    int prev_fg = 7, prev_bg = 0, prev_bold = 0, prev_inverse = 0;
+
+    for (y = 0; y < rows; y++) {
+        for (x = 0; x < cols; x++) {
+            chtype ch = mvwinch(stdscr, y, x);
+            int c = ch & A_CHARTEXT;
+            int attrs = ch & A_ATTRIBUTES;
+            int pair = PAIR_NUMBER(ch);
+            short fg = 7, bg = 0;
+            int bold = (attrs & A_BOLD) ? 1 : 0;
+            int inverse = (attrs & A_REVERSE) ? 1 : 0;
+
+            if (pair > 0)
+                pair_content(pair, &fg, &bg);
+
+            /* Emit ANSI escapes only when attributes change */
+            if (fg != prev_fg || bg != prev_bg
+                || bold != prev_bold || inverse != prev_inverse) {
+                fprintf(fp, "\033[0");  /* reset */
+                if (bold) fprintf(fp, ";1");
+                if (inverse) fprintf(fp, ";7");
+                if (fg != 7) fprintf(fp, ";%d", (fg < 8) ? 30 + fg : 90 + fg - 8);
+                if (bg != 0) fprintf(fp, ";%d", (bg < 8) ? 40 + bg : 100 + bg - 8);
+                fprintf(fp, "m");
+                prev_fg = fg;
+                prev_bg = bg;
+                prev_bold = bold;
+                prev_inverse = inverse;
+            }
+
+            /* Handle DEC graphics: SI/SO for line-drawing chars */
+            if (c >= 0x60 && c <= 0x7e && (attrs & A_ALTCHARSET)) {
+                fputc(0x0e, fp);  /* SO: enter line drawing */
+                fputc(c, fp);
+                fputc(0x0f, fp);  /* SI: exit line drawing */
+            } else if (c < 32 || c == 127) {
+                fputc(' ', fp);   /* control chars → space */
+            } else {
+                fputc(c, fp);
+            }
+        }
+        /* Reset attributes at end of line and newline */
+        if (prev_fg != 7 || prev_bg != 0 || prev_bold || prev_inverse) {
+            fprintf(fp, "\033[0m\033[39m\033[49m");
+            prev_fg = 7; prev_bg = 0; prev_bold = 0; prev_inverse = 0;
+        }
+        fputc('\n', fp);
+    }
+}
+
 #endif /* WIZARD */

