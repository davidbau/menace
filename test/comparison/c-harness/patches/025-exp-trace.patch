@@ -220,6 +223,19 @@ repaint_debug_log(const char *fmt, ...)
     fputs("]\n", out);
 }

+void
+exp_log(const char *fmt, ...)
+{
+    va_list ap;
+    if (!rng_logfile || !exp_trace_enabled)
+        return;
+    fputs("^exp[", rng_logfile);
+    va_start(ap, fmt);
+    vfprintf(rng_logfile, fmt, ap);
+    va_end(ap);
+    fputs("]\n", rng_logfile);
+}
+
