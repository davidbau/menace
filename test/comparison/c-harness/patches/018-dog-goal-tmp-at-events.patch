diff --git a/src/dogmove.c b/src/dogmove.c
--- a/src/dogmove.c
+++ b/src/dogmove.c
@@ -532,6 +532,11 @@ dog_goal(
         if ((max_y = omy + SQSRCHRADIUS) >= ROWNO)
             max_y = ROWNO - 1;

+        event_log("dog_goal_start[M%u@%d,%d apport=%u minvent=%d ims=%d range=[%d..%d]x[%d..%d]]",
+                  mtmp->m_id, omx, omy, edog->apport,
+                  dog_has_minvent ? 1 : 0, in_masters_sight ? 1 : 0,
+                  min_x, max_x, min_y, max_y);
+
         /* nearby food is the first choice, then other objects */
         for (obj = fobj; obj; obj = obj->nobj) {
             nx = obj->ox;
@@ -539,32 +544,56 @@ dog_goal(
             if (nx >= min_x && nx <= max_x && ny >= min_y && ny <= max_y) {
                 otyp = dogfood(mtmp, obj);
                 /* skip inferior goals */
-                if (otyp > gg.gtyp || otyp == UNDEF)
+                if (otyp > gg.gtyp || otyp == UNDEF) {
+                    event_log("dog_goal_obj[M%u oid=%u@%d,%d food=%d skip=inf]",
+                              mtmp->m_id, obj->o_id, nx, ny, otyp);
                     continue;
+                }
                 /* avoid cursed items unless starving */
                 if (cursed_object_at(nx, ny)
-                    && !(edog->mhpmax_penalty && otyp < MANFOOD))
+                    && !(edog->mhpmax_penalty && otyp < MANFOOD)) {
+                    event_log("dog_goal_obj[M%u oid=%u@%d,%d food=%d skip=cur]",
+                              mtmp->m_id, obj->o_id, nx, ny, otyp);
                     continue;
+                }
                 /* skip completely unreachable goals */
                 if (!could_reach_item(mtmp, nx, ny)
-                    || !can_reach_location(mtmp, mtmp->mx, mtmp->my, nx, ny))
+                    || !can_reach_location(mtmp, mtmp->mx, mtmp->my, nx, ny)) {
+                    event_log("dog_goal_obj[M%u oid=%u@%d,%d food=%d skip=rch]",
+                              mtmp->m_id, obj->o_id, nx, ny, otyp);
                     continue;
+                }
                 if (otyp < MANFOOD) {
                     if (otyp < gg.gtyp
                         || DDIST(nx, ny) < DDIST(gg.gx, gg.gy)) {
+                        event_log("dog_goal_obj[M%u oid=%u@%d,%d food=%d sel=1]",
+                                  mtmp->m_id, obj->o_id, nx, ny, otyp);
                         gg.gx = nx;
                         gg.gy = ny;
                         gg.gtyp = otyp;
+                    } else {
+                        event_log("dog_goal_obj[M%u oid=%u@%d,%d food=%d sel=0]",
+                                  mtmp->m_id, obj->o_id, nx, ny, otyp);
                     }
                 } else if (gg.gtyp == UNDEF && in_masters_sight
                            && !dog_has_minvent
                            && (!levl[omx][omy].lit || levl[u.ux][u.uy].lit)
-                           && (otyp == MANFOOD || m_cansee(mtmp, nx, ny))
-                           && edog->apport > rn2(8)
-                           && can_carry(mtmp, obj) > 0) {
-                    gg.gx = nx;
-                    gg.gy = ny;
-                    gg.gtyp = APPORT;
+                           && (otyp == MANFOOD || m_cansee(mtmp, nx, ny))) {
+                    int aproll = rn2(8);
+                    int carry_res = (edog->apport > aproll)
+                                        ? can_carry(mtmp, obj) : 0;
+                    int sel = (edog->apport > aproll && carry_res > 0);
+                    event_log("dog_goal_obj[M%u oid=%u@%d,%d food=%d apport=%u rn2_8=%d carry=%d sel=%d]",
+                              mtmp->m_id, obj->o_id, nx, ny, otyp,
+                              edog->apport, aproll, carry_res, sel);
+                    if (sel) {
+                        gg.gx = nx;
+                        gg.gy = ny;
+                        gg.gtyp = APPORT;
+                    }
+                } else {
+                    event_log("dog_goal_obj[M%u oid=%u@%d,%d food=%d skip=apc]",
+                              mtmp->m_id, obj->o_id, nx, ny, otyp);
                 }
             }
         }
@@ -651,6 +680,8 @@ dog_goal(
     } else if (edog) {
         edog->ogoal.x = 0;
     }
+    event_log("dog_goal_end[M%u goal=%d,%d gtyp=%d appr=%d]",
+              mtmp->m_id, gg.gx, gg.gy, gg.gtyp, appr);
     return appr;
 #undef FARAWAY
 }
