diff --git a/src/rnd.c b/src/rnd.c
--- a/src/rnd.c
+++ b/src/rnd.c
@@ -414,11 +414,15 @@ repaint_debug_log(const char *fmt, ...)
 {
     va_list ap;
     FILE *out;
+    long step_index;
+    const char *step_path;
+    int step_key;
     if (!repaint_debug_enabled)
         return;
     out = repaint_debug_file ? repaint_debug_file : stderr;
     fputs("^repaintdbg[", out);
+    step_index = repaint_debug_get_step_index();
+    if (step_index >= 0L)
+        fprintf(out, "step=%ld ", step_index + 1L);
+    step_path = repaint_debug_get_step_path();
+    if (step_path && *step_path)
+        fprintf(out, "path=%s ", step_path);
+    step_key = repaint_debug_get_step_key();
+    if (step_key >= 0)
+        fprintf(out, "key=%d ", step_key);
     va_start(ap, fmt);
     vfprintf(out, fmt, ap);
     va_end(ap);
