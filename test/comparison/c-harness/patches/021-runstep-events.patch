+static long harness_repaint_step_index = -1L;
+static const char *harness_repaint_step_path = (const char *) 0;
+static int harness_repaint_step_keyarg = -1;
+
+staticfn boolean
+runstep_event_enabled(void)
+{
+    static int cached = -1;
+
+    if (cached < 0) {
+        const char *ev = getenv("NETHACK_EVENT_RUNSTEP");
+        if (!ev || !*ev)
+            ev = getenv("WEBHACK_EVENT_RUNSTEP");
+        cached = (ev && *ev && *ev != '0') ? 1 : 0;
+    }
+    return (boolean) cached;
+}
+
+staticfn boolean
+harness_step_spec_match(const char *spec, long step_index)
+{
+    const char *p;
+
+    if (!spec || !*spec)
+        return FALSE;
+    for (p = spec; *p; ) {
+        long start = 0L, end = 0L;
+        char *endptr = 0;
+
+        while (*p == ' ' || *p == '\t' || *p == ',')
+            ++p;
+        if (!*p)
+            break;
+
+        start = strtol(p, &endptr, 10);
+        if (endptr == p) {
+            while (*p && *p != ',')
+                ++p;
+            continue;
+        }
+        p = endptr;
+        while (*p == ' ' || *p == '\t')
+            ++p;
+        end = start;
+        if (*p == '-') {
+            ++p;
+            while (*p == ' ' || *p == '\t')
+                ++p;
+            end = strtol(p, &endptr, 10);
+            if (endptr == p) {
+                end = start;
+            } else {
+                p = endptr;
+            }
+        }
+        if (start <= end) {
+            if (step_index >= start && step_index <= end)
+                return TRUE;
+        } else {
+            if (step_index >= end && step_index <= start)
+                return TRUE;
+        }
+        while (*p && *p != ',')
+            ++p;
+        if (*p == ',')
+            ++p;
+    }
+    return FALSE;
+}
+
+staticfn void
+runstep_maybe_auto_dumpsnap(const char *pathstr, int keyarg)
+{
+    static int initialized = 0;
+    static const char *step_spec = 0;
+    long step_index;
+    char phasebuf[64];
+
+    if (!initialized) {
+        step_spec = getenv("NETHACK_DUMPSNAP_STEPS");
+        if (!step_spec || !*step_spec)
+            step_spec = getenv("WEBHACK_DUMPSNAP_STEPS");
+        initialized = 1;
+    }
+    if (!step_spec || !*step_spec)
+        return;
+    if (!pathstr || strcmp(pathstr, "fresh_cmd"))
+        return;
+
+    step_index = harness_repaint_step_index;
+    if (!harness_step_spec_match(step_spec, step_index))
+        return;
+
+    Sprintf(phasebuf, "auto_step_%ld_path_%s_key_%d",
+            step_index, pathstr ? pathstr : "unknown", keyarg);
+    harness_dump_checkpoint(phasebuf);
+}
+
+staticfn void
+repaint_debug_note_runstep(const char *pathstr, int keyarg)
+{
+    if (!pathstr || !*pathstr)
+        pathstr = "unknown";
+    if (!strcmp(pathstr, "fresh_cmd"))
+        ++harness_repaint_step_index;
+    harness_repaint_step_path = pathstr;
+    harness_repaint_step_keyarg = keyarg;
+}
+
+long
+repaint_debug_get_step_index(void)
+{
+    return harness_repaint_step_index;
+}
+
+const char *
+repaint_debug_get_step_path(void)
+{
+    return harness_repaint_step_path;
+}
+
+int
+repaint_debug_get_step_key(void)
+{
+    return harness_repaint_step_keyarg;
+}
+
+#define RUNSTEP_EVENT(pathstr, keyarg)                                         \
+    do {                                                                       \
+        repaint_debug_note_runstep((pathstr), (keyarg));                        \
+        runstep_maybe_auto_dumpsnap((pathstr), (keyarg));                      \
+        if (runstep_event_enabled())                                           \
+            event_log("runstep[path=%s keyarg=%d cmd=%d cc=%d moves=%ld multi=%d run=%d mv=%d move=%d occ=%d umoved=%d ux=%d uy=%d]", \
+                      (pathstr), (int) (keyarg), gc.cmd_key, gc.command_count, \
+                      svm.moves, gm.multi, svc.context.run, svc.context.mv,    \
+                      svc.context.move, go.occupation ? 1 : 0,                 \
+                      u.umoved ? 1 : 0, u.ux, u.uy);                           \
+    } while (0)
+
