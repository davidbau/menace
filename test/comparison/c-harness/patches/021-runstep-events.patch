+staticfn boolean
+runstep_event_enabled(void)
+{
+    static int cached = -1;
+
+    if (cached < 0) {
+        const char *ev = getenv("NETHACK_EVENT_RUNSTEP");
+        cached = (ev && *ev && *ev != '0') ? 1 : 0;
+    }
+    return (boolean) cached;
+}
+
+#define RUNSTEP_EVENT(pathstr, keyarg)                                         \
+    do {                                                                       \
+        if (runstep_event_enabled())                                           \
+            event_log("runstep[path=%s keyarg=%d cmd=%d cc=%d moves=%ld multi=%d run=%d mv=%d move=%d occ=%d umoved=%d ux=%d uy=%d]", \
+                      (pathstr), (int) (keyarg), gc.cmd_key, gc.command_count, \
+                      svm.moves, gm.multi, svc.context.run, svc.context.mv,    \
+                      svc.context.move, go.occupation ? 1 : 0, u.umoved ? 1 : 0, \
+                      u.ux, u.uy);                                             \
+    } while (0)
 
 void
