 static int rng_caller_line = 0;
 static const char *rng_caller_func = NULL;
+static boolean repaint_trace_enabled = FALSE;
+static boolean repaint_debug_enabled = FALSE;
+static FILE *repaint_debug_file = (FILE *) 0;
 static boolean rng_log_disp = FALSE;
 
 void
 rng_log_init(void)
 {
     const char *logpath = getenv("NETHACK_RNGLOG");
+    const char *repaint = getenv("NETHACK_REPAINT_TRACE");
+    const char *repaint_debug = getenv("NETHACK_REPAINT_DEBUG");
+    const char *repaint_debug_path = getenv("NETHACK_REPAINT_DEBUG_LOG");
     const char *disp = getenv("NETHACK_RNGLOG_DISP");
     if (logpath && *logpath) {
         rng_logfile = fopen(logpath, "w");
         if (rng_logfile)
             setvbuf(rng_logfile, NULL, _IOLBF, 0); /* line-buffered */
     }
+    repaint_trace_enabled = (repaint && *repaint && *repaint != '0') ? TRUE : FALSE;
+    repaint_debug_enabled = (repaint_debug && *repaint_debug && *repaint_debug != '0') ? TRUE : FALSE;
+    if (repaint_debug_path && *repaint_debug_path) {
+        repaint_debug_file = fopen(repaint_debug_path, "a");
+        if (repaint_debug_file)
+            setvbuf(repaint_debug_file, NULL, _IOLBF, 0);
+    }
     rng_log_disp = (disp && *disp && *disp != '0') ? TRUE : FALSE;
 }
 
@@ -179,6 +192,34 @@ event_log(const char *fmt, ...)
     fputc('\n', rng_logfile);
 }
 
+void
+repaint_log(const char *fmt, ...)
+{
+    va_list ap;
+    if (!rng_logfile || !repaint_trace_enabled)
+        return;
+    fputs("^repaint[", rng_logfile);
+    va_start(ap, fmt);
+    vfprintf(rng_logfile, fmt, ap);
+    va_end(ap);
+    fputs("]\n", rng_logfile);
+}
+
+void
+repaint_debug_log(const char *fmt, ...)
+{
+    va_list ap;
+    FILE *out;
+    if (!repaint_debug_enabled)
+        return;
+    out = repaint_debug_file ? repaint_debug_file : stderr;
+    fputs("^repaintdbg[", out);
+    va_start(ap, fmt);
+    vfprintf(out, fmt, ap);
+    va_end(ap);
+    fputs("]\n", out);
+}
+
