+extern void harness_dump_checkpoint(const char *);
+
+/* Optional input event logging for deterministic replay/testing.
+ * Enable by setting NETHACK_KEYLOG to a writable file path.
+ * Optionally set NETHACK_KEYLOG_DELAY_MS to skip initial keypresses.
+ * Each input event is written as one JSON line.
+ */
+static FILE *nh_keylog_fp = (FILE *) 0;
+static boolean nh_keylog_inited = FALSE;
+static long nh_keylog_seq = 0L;
+static int nh_keylog_delay_ms = 0;
+static int nh_dumpsnap_every_input = 0;
+static struct timeval nh_keylog_start_time;
+
+static void
+nh_keylog_init(void)
+{
+    const char *path, *delay_str;
+    const char *key_dump_every_env;
+
+    if (nh_keylog_inited)
+        return;
+    nh_keylog_inited = TRUE;
+    gettimeofday(&nh_keylog_start_time, NULL);
+    delay_str = nh_getenv("NETHACK_KEYLOG_DELAY_MS");
+    if (!delay_str || !*delay_str)
+        delay_str = nh_getenv("WEBHACK_KEYLOG_DELAY_MS");
+    if (delay_str && *delay_str)
+        nh_keylog_delay_ms = atoi(delay_str);
+    key_dump_every_env = nh_getenv("NETHACK_DUMPSNAP_EVERY_KEY");
+    if (!key_dump_every_env || !*key_dump_every_env)
+        key_dump_every_env = nh_getenv("NETHACK_DUMPSNAP_EVERY_INPUT");
+    if (!key_dump_every_env || !*key_dump_every_env)
+        key_dump_every_env = nh_getenv("WEBHACK_DUMPSNAP_EVERY_KEY");
+    if (!key_dump_every_env || !*key_dump_every_env)
+        key_dump_every_env = nh_getenv("NETHACK_DUMPSNAP_INPUT_EVERY");
+    if (!key_dump_every_env || !*key_dump_every_env)
+        key_dump_every_env = nh_getenv("WEBHACK_DUMPSNAP_INPUT_EVERY");
+    nh_dumpsnap_every_input = (key_dump_every_env
+                               && *key_dump_every_env
+                               && *key_dump_every_env != '0');
+    path = nh_getenv("NETHACK_KEYLOG");
+    if (!path || !*path)
+        path = nh_getenv("WEBHACK_KEYLOG");
+    if (!path || !*path)
+        return;
+    nh_keylog_fp = fopen(path, "a");
+    if (!nh_keylog_fp)
+        return;
+    (void) setvbuf(nh_keylog_fp, (char *) 0, _IOLBF, 0);
+}
+
+static void
+nh_keylog_event(int key)
+{
+    const char *seed;
+
+    nh_keylog_init();
+    if (!nh_keylog_fp && !nh_dumpsnap_every_input)
+        return;
+    seed = nh_getenv("NETHACK_SEED");
+    if (!seed)
+        seed = "";
+
+    if (nh_dumpsnap_every_input) {
+        char phasebuf[128];
+        nh_keylog_seq++;
+        Sprintf(phasebuf, "auto_inp_%ld_key_%d_getlin_%d_moveloop_%d",
+                nh_keylog_seq, key, !!program_state.in_getlin, !!program_state.in_moveloop);
+        harness_dump_checkpoint(phasebuf);
+    }
+    if (nh_keylog_fp) {
+        (void) fprintf(
+            nh_keylog_fp,
+            "{\"seq\":%ld,\"key\":%d,\"moves\":%ld,"
+            "\"x\":%d,\"y\":%d,\"dnum\":%d,\"dlevel\":%d,"
+            "\"in_getlin\":%d,\"in_moveloop\":%d,"
+            "\"seed\":\"%s\"}\n",
+            nh_keylog_seq, key, (long) svm.moves,
+            (int) u.ux, (int) u.uy, (int) u.uz.dnum, (int) u.uz.dlevel,
+            !!program_state.in_getlin, !!program_state.in_moveloop, seed);
+    }
+}
