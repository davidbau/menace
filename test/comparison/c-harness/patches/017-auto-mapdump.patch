+/* Compact auto-mapdump for harness captures. */
+staticfn char
+harness_mapdump_cell(int v)
+{
+    if (v < 0)
+        v = 0;
+    if (v <= 9)
+        return (char) ('0' + v);
+    if (v <= 35)
+        return (char) ('a' + (v - 10));
+    if (v <= 61)
+        return (char) ('A' + (v - 36));
+    return 'Z';
+}
+
+staticfn void
+harness_mapdump_emit_run(FILE *fp, int value, int count)
+{
+    if (count <= 0)
+        return;
+    if (count >= 3) {
+        (void) fprintf(fp, "~%d,%c", count, harness_mapdump_cell(value));
+    } else {
+        while (count-- > 0)
+            (void) fputc(harness_mapdump_cell(value), fp);
+    }
+}
+
+staticfn void
+harness_mapdump_rle_grid(FILE *fp, int which)
+{
+    coordxy x, y;
+    for (y = 0; y < ROWNO; y++) {
+        int runval = -1, runlen = 0;
+        if (y > 0)
+            (void) fputc('|', fp);
+        for (x = 0; x < COLNO; x++) {
+            struct rm *loc = &levl[x][y];
+            int v;
+            switch (which) {
+            case 0: v = (int) loc->typ; break;
+            case 1: v = ((int) loc->flags) & 0x1f; break;
+            case 2: v = loc->horizontal ? 1 : 0; break;
+            case 3: v = loc->lit ? 1 : 0; break;
+            case 4: v = ((int) loc->roomno) & 0x3f; break;
+            case 5: v = ((int) loc->wall_info) & 0x1f; break;
+            default: v = 0; break;
+            }
+            if (runlen == 0) {
+                runval = v;
+                runlen = 1;
+            } else if (v == runval) {
+                runlen++;
+            } else {
+                harness_mapdump_emit_run(fp, runval, runlen);
+                runval = v;
+                runlen = 1;
+            }
+        }
+        harness_mapdump_emit_run(fp, runval, runlen);
+    }
+}
+
+staticfn void
+harness_mapdump_sparse_lists(FILE *fp)
+{
+    struct obj *otmp;
+    struct monst *mtmp;
+    struct trap *ttmp;
+    struct engr *ep;
+    boolean first;
+
+    (void) fputc('O', fp);
+    first = TRUE;
+    for (otmp = fobj; otmp; otmp = otmp->nobj) {
+        if (!isok(otmp->ox, otmp->oy))
+            continue;
+        (void) fprintf(fp, "%s%d,%d,%d,%ld",
+                       first ? "" : ";",
+                       (int) otmp->ox, (int) otmp->oy,
+                       (int) otmp->otyp, (long) otmp->quan);
+        first = FALSE;
+    }
+    (void) fputc('\n', fp);
+
+    (void) fputc('Q', fp);
+    first = TRUE;
+    for (otmp = fobj; otmp; otmp = otmp->nobj) {
+        if (!isok(otmp->ox, otmp->oy))
+            continue;
+        (void) fprintf(fp, "%s%u,%d,%d,%d,%ld,%d,%d,%d,%u,%d,%d,%d,%d,%d",
+                       first ? "" : ";",
+                       otmp->o_id,
+                       (int) otmp->ox, (int) otmp->oy,
+                       (int) otmp->otyp, (long) otmp->quan,
+                       (int) otmp->where,
+                       otmp->cursed ? 1 : 0,
+                       otmp->blessed ? 1 : 0,
+                       (unsigned) otmp->owt,
+                       (int) otmp->invlet,
+                       otmp->olocked ? 1 : 0,
+                       otmp->obroken ? 1 : 0,
+                       otmp->otrapped ? 1 : 0,
+                       otmp->no_charge ? 1 : 0);
+        first = FALSE;
+    }
+    (void) fputc('\n', fp);
+
+    (void) fputc('M', fp);
+    first = TRUE;
+    for (mtmp = fmon; mtmp; mtmp = mtmp->nmon) {
+        if (!isok(mtmp->mx, mtmp->my))
+            continue;
+        (void) fprintf(fp, "%s%d,%d,%d,%d",
+                       first ? "" : ";",
+                       (int) mtmp->mx, (int) mtmp->my,
+                       (int) monsndx(mtmp->data), (int) mtmp->mhp);
+        first = FALSE;
+    }
+    (void) fputc('\n', fp);
+
+    (void) fputc('N', fp);
+    first = TRUE;
+    for (mtmp = fmon; mtmp; mtmp = mtmp->nmon) {
+        if (!isok(mtmp->mx, mtmp->my))
+            continue;
+        (void) fprintf(fp, "%s%u,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%u,%u,%d",
+                       first ? "" : ";",
+                       mtmp->m_id,
+                       (int) mtmp->mx, (int) mtmp->my,
+                       (int) monsndx(mtmp->data),
+                       (int) mtmp->mhp, (int) mtmp->mhpmax,
+                       (int) mtmp->mtame,
+                       mtmp->mpeaceful ? 1 : 0,
+                       mtmp->msleeping ? 1 : 0,
+                       (int) mtmp->mfrozen,
+                       mtmp->mcanmove ? 1 : 0,
+                       mtmp->mtrapped ? 1 : 0,
+                       (unsigned) mtmp->m_ap_type,
+                       (unsigned) mtmp->mappearance,
+                       harness_mapdump_minvent_count(mtmp));
+        first = FALSE;
+    }
+    (void) fputc('\n', fp);
+
+    (void) fputc('K', fp);
+    first = TRUE;
+    for (ttmp = gf.ftrap; ttmp; ttmp = ttmp->ntrap) {
+        if (!isok(ttmp->tx, ttmp->ty))
+            continue;
+        (void) fprintf(fp, "%s%d,%d,%d",
+                       first ? "" : ";",
+                       (int) ttmp->tx, (int) ttmp->ty, (int) ttmp->ttyp);
+        first = FALSE;
+    }
+    (void) fputc('\n', fp);
+
+    (void) fputc('J', fp);
+    first = TRUE;
+    for (ttmp = gf.ftrap; ttmp; ttmp = ttmp->ntrap) {
+        if (!isok(ttmp->tx, ttmp->ty))
+            continue;
+        (void) fprintf(fp, "%s%d,%d,%d,%d,%d,%d,%d,%d",
+                       first ? "" : ";",
+                       (int) ttmp->tx, (int) ttmp->ty, (int) ttmp->ttyp,
+                       ttmp->tseen ? 1 : 0,
+                       ttmp->once ? 1 : 0,
+                       ttmp->madeby_u ? 1 : 0,
+                       (int) ttmp->teledest.x, (int) ttmp->teledest.y);
+        first = FALSE;
+    }
+    (void) fputc('\n', fp);
+
+    (void) fputc('E', fp);
+    first = TRUE;
+    for (ep = head_engr; ep; ep = ep->nxt_engr) {
+        if (!isok(ep->engr_x, ep->engr_y))
+            continue;
+        (void) fprintf(fp, "%s%d,%d,%d,%u,%d,%d",
+                       first ? "" : ";",
+                       (int) ep->engr_x, (int) ep->engr_y,
+                       (int) ep->engr_type,
+                       (unsigned) (ep->engr_txt[actual_text]
+                                   ? strlen(ep->engr_txt[actual_text]) : 0),
+                       ep->nowipeout ? 1 : 0,
+                       ep->guardobjects ? 1 : 0);
+        first = FALSE;
+    }
+    (void) fputc('\n', fp);
+}
+
+staticfn int
+harness_mapdump_minvent_count(struct monst *mtmp)
+{
+    int n = 0;
+    struct obj *otmp;
+
+    if (!mtmp)
+        return 0;
+    for (otmp = mtmp->minvent; otmp; otmp = otmp->nobj)
+        n++;
+    return n;
+}
+
+staticfn void
+harness_auto_mapdump(void)
+{
+    const char *dir = nh_getenv("NETHACK_MAPDUMP_DIR");
+    static long dump_serial = 0;
+    char dump_id[64], pathbuf[BUFSZ];
+    FILE *fp;
+
+    if (!dir || !*dir)
+        return;
+
+    (void) Snprintf(dump_id, sizeof dump_id, "d%dl%d_%03ld",
+                    (int) u.uz.dnum, (int) u.uz.dlevel, ++dump_serial);
+    (void) Snprintf(pathbuf, sizeof pathbuf, "%s/%s", dir, dump_id);
+
+    fp = fopen(pathbuf, "w");
+    if (!fp) {
+        raw_printf("mapdump: cannot open %s for writing.", pathbuf);
+        return;
+    }
+
+    (void) fputc('T', fp); harness_mapdump_rle_grid(fp, 0); (void) fputc('\n', fp);
+    (void) fputc('F', fp); harness_mapdump_rle_grid(fp, 1); (void) fputc('\n', fp);
+    (void) fputc('H', fp); harness_mapdump_rle_grid(fp, 2); (void) fputc('\n', fp);
+    (void) fputc('L', fp); harness_mapdump_rle_grid(fp, 3); (void) fputc('\n', fp);
+    (void) fputc('R', fp); harness_mapdump_rle_grid(fp, 4); (void) fputc('\n', fp);
+    (void) fputc('W', fp); harness_mapdump_rle_grid(fp, 5); (void) fputc('\n', fp);
+    (void) fprintf(fp, "U%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%ld,%d,%d,%d,%d,%d\n",
+                   (int) u.ux, (int) u.uy,
+                   (int) u.uhp, (int) u.uhpmax,
+                   (int) u.uen, (int) u.uenmax,
+                   (int) gm.multi, (int) u.utrap, (int) u.utraptype,
+                   (int) svc.context.move, (long) svm.moves,
+                   Confusion ? 1 : 0, Stunned ? 1 : 0,
+                   Blind ? 1 : 0, Hallucination ? 1 : 0,
+                   Fumbling ? 1 : 0);
+    (void) fprintf(fp, "A%ld,%ld\n", (long) svm.moves, (long) gh.hero_seq);
+    harness_mapdump_sparse_lists(fp);
+    (void) fclose(fp);
+
+    event_log("mapdump[%s]", dump_id);
+}
 
